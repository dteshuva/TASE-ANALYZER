# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server port
PORT=3001

# Comma-separated list of allowed frontend origins (for CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Model to use (claude-opus-4-8, claude-sonnet-4-6, etc.)
CLAUDE_MODEL=claude-sonnet-4-6

# Cache TTL in seconds (analysis results cached per ticker)
CACHE_TTL_SECONDS=300

# Shared access password for the app. When set, users must enter this password
# once per device to use the app. Leave blank to disable auth (open API).
APP_PASSWORD=changeme

# Set to "production" on your host so internal error details are not returned
# to clients (5xx responses become a generic message). Leave unset locally.
# NODE_ENV=production
